# Backend FastAPI base URL. Backend has /v1 prefix.
VITE_API_BASE_URL=http://127.0.0.1:8000/v1

# Firebase Web App config from Firebase Console -> Project settings -> Your apps -> Web app.
# These are frontend Auth config values, not Firebase Admin secrets.
# Photos are uploaded through the API to private Supabase Storage, so there is no Firebase Storage bucket here.
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Optional UI defaults.
VITE_DEFAULT_TIMEZONE=Europe/Helsinki
VITE_APP_NAME=Calnito
